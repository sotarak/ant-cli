{
  "name": "@sotarak/ant-cli",
  "version": "0.1.2",
  "description": "CLI tool to initialize .agent configuration for various frameworks — powered by Antigravity",
  "type": "module",
  "bin": {
    "ant": "./dist/bin/ant.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "dev": "tsx bin/ant.ts",
    "build": "tsup",
    "format": "prettier --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "release": "changeset publish"
  },
  "keywords": [
    "cli",
    "agent",
    "antigravity",
    "ai",
    "scaffold",
    "dotfiles"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.4",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@changesets/cli": "^2.30.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.2",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
